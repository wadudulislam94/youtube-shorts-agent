# ── YouTube Shorts Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
#
# Required (both free):
#   1. GEMINI_API_KEY   → https://aistudio.google.com/app/apikey
#   2. PIXABAY_API_KEY  → https://pixabay.com/api/docs/
#   3. YouTube OAuth    → set up credentials/client_secrets.json (see README)
# ─────────────────────────────────────────────────────────────────────────────

# AI Script & SEO (Google Gemini - FREE, 1,500 req/day)
GEMINI_API_KEY=your_gemini_api_key_here

# Background Videos (Pixabay - FREE, unlimited)
PIXABAY_API_KEY=your_pixabay_api_key_here

# TTS Voice (edge-tts - FREE, no key needed)
# Options: random | en-US-AriaNeural | en-US-GuyNeural | en-GB-RyanNeural
TTS_VOICE=random

# Whisper Model Size (runs locally)
# Options: tiny | base | small | medium
WHISPER_MODEL=base

# Content Niche
# Options: art | facts | finance | motivation | history | tech
CONTENT_NICHE=art

# Shorts per scheduler run
SHORTS_PER_RUN=1

# Run every N hours (6 = 4 videos per day)
SCHEDULE_INTERVAL_HOURS=6

# YouTube OAuth paths (don't change unless you know what you're doing)
YOUTUBE_CLIENT_SECRETS=credentials/client_secrets.json
YOUTUBE_TOKEN_FILE=credentials/youtube_token.json
